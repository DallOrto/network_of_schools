        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateSchoolRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Escola criada com sucesso",
            "content": {
              "application/json": {
