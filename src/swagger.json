          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/internal/compliance-result/{attemptId}": {
      "post": {
        "tags": ["Students"],
        "summary": "Webhook de resultado de compliance (uso interno)",
        "description": "**Uso interno entre APIs.** Chamado pelo serviço de compliance (API 2) quando o processamento de um job é concluído.\n\n**Autenticação:** `x-api-key` (não usa JWT).\n\nSe aprovado: cria o `User` + `Student` e atualiza o `EnrollmentAttempt` para `APPROVED`.\nSe reprovado: atualiza o `EnrollmentAttempt` para `REJECTED` com o motivo.",
        "security": [],
        "parameters": [
          {
            "name": "attemptId",
            "in": "path",
            "required": true,
            "description": "ID do EnrollmentAttempt criado na solicitação original",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["jobId", "complianceId", "approved", "complianceStudentId"],
                "properties": {
                  "jobId": { "type": "string" },
                  "complianceId": { "type": "string" },
                  "approved": { "type": "boolean" },
                  "reason": { "type": "string", "nullable": true },
                  "complianceStudentId": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Resultado processado com sucesso" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/students/{document}/enrollment-attempts": {
      "get": {
        "tags": ["Students"],
        "summary": "Listar histórico de tentativas de matrícula",
        "description": "**Roles permitidas:** `super_admin`, `network_admin`, `school_admin`.\n\nRetorna o histórico completo de tentativas de cadastro de um aluno identificado pelo `document`, incluindo aprovações e reprovações com seus respectivos motivos e IDs de compliance. Ordenado da tentativa mais recente para a mais antiga.",
        "parameters": [
          {
            "name": "document",
            "in": "path",
            "required": true,
            "description": "Documento (CPF ou similar) do aluno",
            "schema": { "type": "string", "example": "12345678900" }
          }
        ],
        "responses": {
          "200": {
            "description": "Histórico de tentativas de matrícula",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/EnrollmentAttemptResponse" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
