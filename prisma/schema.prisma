generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  network_admin
  school_admin
  teacher
  student
}

model User {
  id        String    @id @default(uuid())
  document  String    @unique
  password  String
  role      UserRole
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())

  teacher Teacher?
  student Student?
  admin   Admin?

  @@map("users")
}

model Network {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  School School[]
  Admin  Admin[]

  @@map("networks")
}

model School {
  id        String   @id @default(uuid())
  name      String
  address   String
  networkId String
  network   Network  @relation(fields: [networkId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  Teacher           Teacher[]
  Student           Student[]
  Class             Class[]
  Admin             Admin[]
  EnrollmentAttempt EnrollmentAttempt[]

  @@map("schools")
}

model Admin {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  name      String
  networkId String?
  schoolId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  network Network? @relation(fields: [networkId], references: [id])
  school  School?  @relation(fields: [schoolId], references: [id])

  @@map("admins")
}

model Teacher {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  name      String
  birthDate DateTime
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  TeacherClass TeacherClass[]

  @@map("teachers")
}

model Student {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  name      String
  birthDate DateTime
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  StudentClass StudentClass[]

  @@map("students")
}

model Class {
  id          String    @id @default(uuid())
  name        String
  classDay    WeekDays
  startTime   String
  endTime     String
  maxStudents Int
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())
  deletedAt   DateTime?

  StudentClass StudentClass[]
  TeacherClass TeacherClass[]

  @@unique([name, classDay, startTime, endTime])
  @@map("classes")
}

enum WeekDays {
  Monday
  Tuesday
  Wednesday
  Thursday
  Friday
  Saturday
  Sunday
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum AuditEntity {
  NETWORK
  SCHOOL
  TEACHER
  STUDENT
  CLASS
  CLASS_TEACHER
  CLASS_STUDENT
  ADMIN
}

model AuditLog {
  id        String      @id @default(uuid())
  actorId   String
  actorRole String
  action    AuditAction
  entity    AuditEntity
  entityId  String
  metadata  Json?
  createdAt DateTime    @default(now())

  @@map("audit_logs")
}

model StudentClass {
  id        String  @id @default(uuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  classId   String
  class     Class   @relation(fields: [classId], references: [id])

  @@unique([studentId, classId])
  @@map("StudentsClasses")
}

model TeacherClass {
  id        String  @id @default(uuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  classId   String
  class     Class   @relation(fields: [classId], references: [id])

  @@unique([teacherId, classId])
  @@map("TeachersClasses")
}

enum EnrollmentAttemptStatus {
  APPROVED
  REJECTED
  ERROR
}

model EnrollmentAttempt {
  id                  String                  @id @default(uuid())
  complianceStudentId String
  studentId           String?
  studentName         String
  studentDocument     String
  schoolId            String
  school              School                  @relation(fields: [schoolId], references: [id])
  status              EnrollmentAttemptStatus
  complianceId        String?
  rejectionReason     String?
  attemptedAt         DateTime                @default(now())

  @@map("enrollment_attempts")
}
