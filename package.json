{
  "name": "prisma",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "dev": "ts-node-dev --exit-child --transpile-only --ignore-watch node_modules src/server.ts",
    "build": "prisma generate && tsc && npx prisma migrate resolve --rolled-back 20260405000000_add_users_table || true && npx prisma migrate deploy && npx prisma db seed",
    "start": "node dist/server.js",
    "test": "dotenv -e .env.test npx prisma migrate dev && jest --coverage true",
    "test-unique": "dotenv -e .env.test npx prisma migrate dev && jest -t",
    "type-check": "tsc --noEmit",
    "migrate:dev": "prisma migrate dev",
    "seed": "ts-node prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@faker-js/faker": "^7.3.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.0.1",
    "express": "^4.17.2",
    "express-async-errors": "^3.1.1",
    "faker": "^6.6.6",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^5.22.0",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^1.1.8",
    "typescript": "^4.5.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.13",
    "@types/jest": "^27.4.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^17.0.24",
    "@types/pg": "^8.6.5",
    "@types/supertest": "^2.0.12",
    "@types/swagger-ui-express": "^4.1.8",
    "dotenv-cli": "^6.0.0",
    "jest": "^28.1.3",
    "nock": "^14.0.11",
    "pg": "^8.7.3",
    "supertest": "^6.2.2",
    "ts-jest": "^28.0.5"
  }
}
